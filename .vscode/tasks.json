{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-debug",
            "type": "shell",
            "command": "npm run build && cd src-tauri && cargo build",
            "windows": {
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": ["/d", "/c"]
                    }
                }
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$rustc",
            "group": "build"
        }
    ]
}